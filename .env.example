# =========================
# LLM Provider Templates
# =========================
#
# 说明：
# 1. 这个文件是模板，不包含真实密钥。
# 2. 项目当前会读取仓库根目录 `.env`，所以你可以把本文件复制为 `.env` 后再填写真实值。
# 3. 第一版 provider 抽象支持：
#    - DeepSeek
#    - GLM
#    - OpenAI
# 4. chat 类调用默认通过 profile 选择 provider：
#    - DEFAULT_CHAT_PROVIDER 控制大多数普通聊天/创作调用
#    - CREATIVE_REVIEW_PROVIDER 控制剧本审查 review_script
#
# 可选 provider 名称：
# - deepseek
# - glm
# - openai


# =========================
# LangSmith Tracing
# =========================
#
# 说明：
# 1. 默认关闭，避免本地 smoke/eval 把测试请求上报到 LangSmith。
# 2. 需要观测线上/调试链路时，再改为 true。
# 3. 真实 API Key 只写入 `.env`，不要提交到代码仓库。
# 4. 代码会自动把 LANGSMITH_* 兼容映射到旧版 LANGCHAIN_* 变量。

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_your_api_key_here
LANGSMITH_PROJECT=langgraph-agent-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com


# =========================
# Local Structured Logging
# =========================
#
# 本地应用日志会输出为一行 JSON，便于 stdout 采集器、容器日志和日志平台解析。
# 可选级别：DEBUG / INFO / WARNING / ERROR

APP_LOG_LEVEL=INFO


# =========================
# Routing / Profile Defaults
# =========================

# 大多数 chat 类任务默认走哪个 provider
DEFAULT_CHAT_PROVIDER=deepseek

# 剧本 planner 默认走哪个 provider
CREATIVE_PLANNER_PROVIDER=deepseek

# 剧本写作默认走哪个 provider
CREATIVE_WRITE_PROVIDER=deepseek

# 剧本审查任务默认走哪个 provider
CREATIVE_REVIEW_PROVIDER=glm


# =========================
# Legacy Fallback Fields
# =========================
#
# 说明：
# 当前代码为了兼容老逻辑，DeepSeek 仍会回退读取这三项：
# - API_KEY
# - BASE_URL
# - MODEL
#
# 如果你已经完整填写了 DEEPSEEK_*，这三项可以保留为空；
# 但为了兼容旧代码和旧脚本，建议也一起填上。

API_KEY=your_deepseek_api_key_here
BASE_URL=https://api.deepseek.com
MODEL=deepseek-chat


# =========================
# DeepSeek
# =========================

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat


# =========================
# GLM
# =========================
#
# 审查、轻判断类任务可以优先尝试挂在 GLM 上。

GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4-flash


# =========================
# OpenAI
# =========================
#
# 如果你后面想把某些 profile 切到 OpenAI，只需要填这组配置，
# 然后再调整 DEFAULT_CHAT_PROVIDER / CREATIVE_REVIEW_PROVIDER 即可。

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini


# =========================
# Embedding
# =========================
#
# embedding 现在已经接入统一 provider 抽象，但仍保留独立 profile：
# - default_embedding
# - doc_embedding
# - memory_embedding
# - query_embedding
#
# 配置方式有两种：
# 1. 最简单：继续只填 EMBEDDING_*，并让 EMBEDDING_PROVIDER=embedding
# 2. 更统一：把 EMBEDDING_PROVIDER / DOC_EMBEDDING_PROVIDER / QUERY_EMBEDDING_PROVIDER
#    指向 deepseek / glm / openai，直接复用对应 provider 配置

EMBEDDING_PROVIDER=embedding
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
EMBEDDING_MODEL=embedding-3

# 请求级 embedding 缓存容量。同一轮请求内相同 profile/model/text 会复用结果；设为 0 可关闭。
EMBEDDING_CACHE_MAX_ITEMS=128

# 如果文档、记忆、查询三类 embedding 想分开选模型/厂商，可以继续细配：
# DOC_EMBEDDING_PROVIDER=glm
# DOC_EMBEDDING_MODEL=embedding-3
# MEMORY_EMBEDDING_PROVIDER=glm
# MEMORY_EMBEDDING_MODEL=embedding-3
# QUERY_EMBEDDING_PROVIDER=glm
# QUERY_EMBEDDING_MODEL=embedding-3


# =========================
# Vector Store / Chunking
# =========================
#
# 当前迁移方案：
# 1. 项目外部先算 embedding
# 2. 再把向量写入 Chroma
# 3. doc 做 chunk
# 4. memory 暂时保持整条存储，不做 chunk

VECTOR_STORE_PROVIDER=json
CHROMA_PERSIST_DIR=data/chroma
CHROMA_DOC_COLLECTION=docs
CHROMA_MEMORY_COLLECTION=memory

DOC_CHUNKING_ENABLED=true
DOC_CHUNK_SIZE_CHARS=280
DOC_CHUNK_OVERLAP_CHARS=60
DOC_MIN_CHUNK_CHARS=40


# =========================
# LangGraph Checkpointing
# =========================
#
# checkpoint 保存 graph state，用于 session 跨重启恢复。
# conversation_history.sqlite3 仍只保存“用户问过什么”的业务流水。

LANGGRAPH_CHECKPOINT_ENABLED=true
LANGGRAPH_CHECKPOINT_SQLITE_PATH=data/langgraph_checkpoints.sqlite3
